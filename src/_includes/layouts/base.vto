<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Theme: apply before paint to avoid FOUC -->
  <script>
    (function () {
      const stored = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches;
      if (stored === "dark" || (!stored && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" />
  <link rel="stylesheet" href="{{ '/styles/main.css' |> url }}" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.author.rss |> url }}" />
</head>

<body
  class="bg-stone-50 dark:bg-stone-950 text-stone-800 dark:text-stone-200 min-h-screen flex flex-col font-sans antialiased pt-20">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50
             focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-medium
             focus:bg-stone-900 focus:text-stone-100 dark:focus:bg-stone-100 dark:focus:text-stone-900">Skip to main
    content</a>

  {{ include "components/header.vto" }}

  <main id="main-content" class="flex-1 w-full px-4 py-10">
    <div data-pagefind-body>{{ content }}</div>
  </main>

  <footer
    class="border-t border-stone-200 dark:border-stone-800 py-8 text-center text-sm text-stone-400 dark:text-stone-500">
    <p>
      &copy; {{ "now" |> date("yyyy") }} {{ site.author.name }}
      &nbsp;&middot;&nbsp;
      <a href="{{ site.author.rss |> url }}"
        class="hover:text-stone-600 dark:hover:text-stone-300 transition-colors">RSS</a>
      &nbsp;&middot;&nbsp;
      <a href="{{ site.author.github }}" target="_blank" rel="noopener"
        class="hover:text-stone-600 dark:hover:text-stone-300 transition-colors">GitHub</a>
    </p>
  </footer>

  <!-- GitHub Card custom element -->
  <script type="module" src="{{ '/js/github-card.js' |> url }}"></script>

  {{ include "components/search-dialog.vto" }}
</body>

</html>