<a
  href="{{ ('/tags/' + tag) |> slugify |> url }}"
  class="inline-block text-[11px] font-medium px-2.5 py-1 rounded-md
         bg-stone-100 text-stone-700 hover:bg-stone-200 border border-stone-200
         dark:bg-stone-800 dark:text-stone-300 dark:hover:bg-stone-700 dark:border-stone-700
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 focus-visible:ring-offset-1 dark:focus-visible:ring-stone-400
         transition-colors no-underline"
>{{ tag }}</a>
